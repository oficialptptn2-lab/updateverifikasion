.loading-screen{
position:fixed;
inset:0;
background:#fff;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
z-index:9999;
}
.spinner{
width:55px;
height:55px;
border:4px solid #eee;
border-top:4px solid #ff0033;
border-radius:50%;
animation:spin 1s linear infinite;
}
@keyframes spin{
100%{transform:rotate(360deg)}
}
